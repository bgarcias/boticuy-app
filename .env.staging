# Entorno de staging (ver ARQUITECTURA.md → "2. Entornos").
# WordPress de staging aún no tiene dominio propio, solo IP — por eso las URLs
# son http:// en vez de https://. app.config.js detecta esto automáticamente
# y activa el cleartext scoped a este host únicamente (ver plugins/withCleartextHost.js).
#
# Para usar este entorno:      npm run start:staging   (o android:staging)
# Para volver a producción:    npm start                (no requiere tocar nada)
EXPO_PUBLIC_STORE_API_URL=http://35.209.93.250/wp-json/wc/store/v1
EXPO_PUBLIC_WP_API_URL=http://35.209.93.250/wp-json/wp/v2
EXPO_PUBLIC_BFF_URL=http://35.209.93.250/wp-json/boticuy-app/v1

# Habilita la creación real de pedidos (POST /order) solo en este entorno.
# Ver src/api/orders.ts — sin esta variable, createOrder() no llama al backend.
EXPO_PUBLIC_ORDERS_ENABLED=true
